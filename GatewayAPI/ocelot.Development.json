{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/mangas/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5010
        }
      ],
      "UpstreamPathTemplate": "/api/v1/mangas/{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Post",
        "Put",
        "Delete",
        "Patch",
        "Options"
      ]
    },
    {
      "DownstreamPathTemplate": "/hubs/notification/negotiate",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5010
        }
      ],
      "UpstreamPathTemplate": "/api/v1/hubs/notification/negotiate",
      "UpstreamHttpMethod": [
        "Post",
        "Options"
      ]
    },
    {
      "DownstreamPathTemplate": "/hubs/notification",
      "DownstreamScheme": "ws",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5010
        }
      ],
      "UpstreamPathTemplate": "/api/v1/hubs/notification",
      "UpstreamHttpMethod": [
        "Get"
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}
